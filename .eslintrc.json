{
  "ignorePatterns": ["**/*.base64.ts"],
  "overrides": [
    {
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "plugin:@angular-eslint/recommended",
        "plugin:@angular-eslint/template/process-inline-templates",
        "plugin:import/errors",
        "plugin:import/warnings",
        "plugin:import/typescript"
      ],
      "files": ["*.ts"],
      "parserOptions": {
        "createDefaultProgram": true,
        "project": ["tsconfig.json", "tsconfig.spec.json"]
      },
      "plugins": [
        "eslint-plugin-rxjs",
        "rxjs-angular",
        "@typescript-eslint",
        "import"
      ],
      "rules": {
        "@typescript-eslint/no-empty-function": 2,
        // We allow the use of `any` in some cases, but we want to be aware of when it is used so that we can eventually remove it.
        "@typescript-eslint/no-explicit-any": 1,
        "@typescript-eslint/no-inferrable-types": 2,
        // beginning of explicitly enabled rules
        "max-len": [
          "error",
          {
            "code": 140,
            // prettier does not ever wrap long import lines (with only one imported item) so we need to ignore them here
            "ignorePattern": "^import\\s+.*\\s+from\\s+|^export\\s+.*\\s+from\\s+"
          }
        ],
        "no-console": [
          "error",
          {
            "allow": ["warn", "error"]
          }
        ],
        "import/no-unresolved": "off",
        "import/no-deprecated": "error",
        "@angular-eslint/component-selector": [
          "error",
          {
            "prefix": ["baw"],
            "style": "kebab-case",
            "type": "element"
          }
        ],
        "@angular-eslint/directive-selector": [
          "error",
          {
            "prefix": ["baw"],
            "style": "camelCase",
            "type": "attribute"
          }
        ],
        // TODO: Remove this rule once we migrate all components to use inject()
        // see: https://github.com/QutEcoacoustics/workbench-client/issues/2306
        "@angular-eslint/prefer-inject": "off",
        "@angular-eslint/use-component-view-encapsulation": "error",
        "@typescript-eslint/await-thenable": "error",
        "@typescript-eslint/consistent-type-definitions": "error",
        "@typescript-eslint/prefer-as-const": "error",
        "@typescript-eslint/dot-notation": "off",
        "@typescript-eslint/explicit-member-accessibility": [
          "error",
          {
            "accessibility": "explicit"
          }
        ],
        "@typescript-eslint/explicit-module-boundary-types": "off",
        "@typescript-eslint/member-delimiter-style": [
          "off",
          {
            "multiline": {
              "delimiter": "none",
              "requireLast": true
            },
            "singleline": {
              "delimiter": "semi",
              "requireLast": false
            }
          }
        ],
        "@typescript-eslint/member-ordering": "off",
        "@typescript-eslint/no-shadow": "error",
        "@typescript-eslint/no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "destructuredArrayIgnorePattern": "^_"
          }
        ],
        "@typescript-eslint/quotes": [
          "error",
          "double",
          {
            "avoidEscape": true
          }
        ],
        "@typescript-eslint/semi": ["off", null],
        "arrow-parens": ["off", "always"],
        "brace-style": ["off"],
        "eqeqeq": ["error", "always"],
        "guard-for-in": "off",
        "import/order": "error",
        "no-implicit-globals": "error",
        "no-multiple-empty-lines": "error",
        "no-shadow": "off",
        "no-underscore-dangle": "off",
        "quotes": [
          "error",
          "double",
          {
            "avoidEscape": true
          }
        ],
        "rxjs-angular/prefer-takeuntil": [
          "error",
          {
            "checkDestroy": false
          }
        ],
        "rxjs/no-create": "error",
        "rxjs/no-internal": "error",
        "rxjs/no-nested-subscribe": "error",
        "rxjs/no-unsafe-takeuntil": "error",
        "space-before-function-paren": "off"
      }
    },
    {
      "extends": ["plugin:@angular-eslint/template/recommended"],
      "files": ["*.html"],
      "rules": {}
    }
  ],
  "root": true
}
